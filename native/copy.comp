#version 450

layout(local_size_x = 256) in;
layout(set = 0, binding = 0, std430) readonly buffer Source {
  uvec4 values[];
} source_buffer;
layout(set = 0, binding = 1, std430) writeonly buffer Destination {
  uvec4 values[];
} destination_buffer;

void main() {
  destination_buffer.values[gl_GlobalInvocationID.x] =
      source_buffer.values[gl_GlobalInvocationID.x];
}
